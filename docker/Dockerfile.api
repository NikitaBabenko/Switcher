FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY src/Switcher.Core/Switcher.Core.csproj src/Switcher.Core/
COPY src/Switcher.Api/Switcher.Api.csproj src/Switcher.Api/
RUN dotnet restore src/Switcher.Api/Switcher.Api.csproj
COPY src/Switcher.Core src/Switcher.Core
COPY src/Switcher.Api src/Switcher.Api
RUN dotnet publish src/Switcher.Api/Switcher.Api.csproj -c Release -o /out --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /out ./
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "Switcher.Api.dll"]
