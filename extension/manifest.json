{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_appName__",
  "description": "__MSG_appShortDescription__",
  "version": "1.0.2",
  "author": "VibeNest",
  "homepage_url": "https://vibenest.net",
  "permissions": ["contextMenus", "storage", "activeTab", "scripting", "notifications", "clipboardWrite", "sidePanel"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "__MSG_actionTitle__",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html",
  "commands": {
    "convert-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "__MSG_commandDescription__"
    }
  }
}
